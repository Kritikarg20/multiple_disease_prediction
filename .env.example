# GEMINI_API_KEY: Optional. Enables AI chatbot responses via Gemini.
# Without it, the built-in clinical fallback engine is used automatically.
MISTRAL_API_KEY=YOUR_MISTRAL_API_KEY

# ML_SERVICE_URL: URL of the Python FastAPI ML inference service.
# Default: http://localhost:8000
# Run locally with: cd ml/service && uvicorn app:app --port 8000
ML_SERVICE_URL="http://localhost:8000"
